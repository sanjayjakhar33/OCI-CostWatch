APP_NAME=OCI CostWatch
APP_ENV=development
LOG_LEVEL=INFO
DEMO_MODE=true

DATABASE_URL=postgresql+psycopg://costwatch:costwatch@postgres:5432/costwatch
REDIS_URL=redis://redis:6379/0

OCI_CONFIG_FILE=~/.oci/config
OCI_PROFILE=DEFAULT
OCI_REGION=us-ashburn-1
OCI_COMPARTMENT_ID=ocid1.compartment.oc1..exampleuniqueID

MANDATORY_TAGS=["Environment","Owner","Project"]

COST_SPIKE_THRESHOLD_PCT=50
IDLE_CPU_THRESHOLD_PCT=5
IDLE_DAYS_THRESHOLD=7
ZOMBIE_SNAPSHOT_DAYS=30
SCAN_INTERVAL_COST_SECONDS=86400
SCAN_INTERVAL_ZOMBIE_SECONDS=21600
SCAN_INTERVAL_EXPOSURE_SECONDS=43200
SCAN_INTERVAL_IDLE_SECONDS=21600

SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
